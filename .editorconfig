root = true

[*]
indent_style = space
end_of_line = lf
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

[*.{csproj,vbproj,vcxproj,proj,projitems,shproj}]
indent_size = 2

[*.{props,targets,ruleset,config,nuspec,resx,vsixmanifest,vsct}]
indent_size = 2

[*.{yml,yaml,json}]
indent_size = 2

[*.{ts,tsx,css,scss,less}]
indent_size = 2

[*.cs]
indent_size = 4

# 见 .github/copilot-instructions.md「C# 代码规范」：使用显式类型，而不要使用 var。
csharp_style_var_for_built_in_types = false:warning
csharp_style_var_when_type_is_apparent = false:warning
csharp_style_var_elsewhere = false:warning

# 见 .github/copilot-instructions.md：访问类成员时使用 this. 前缀（主构造函数捕获参数除外，
# 这条规则只影响字段/属性/方法/事件的访问，不影响主构造函数参数）。
dotnet_style_qualification_for_field = true:warning
dotnet_style_qualification_for_property = true:warning
dotnet_style_qualification_for_method = true:warning
dotnet_style_qualification_for_event = true:warning

# 文件作用域命名空间（已是既有约定，这里显式声明并纳入 TreatWarningsAsErrors 校验）。
csharp_style_namespace_declarations = file_scoped:warning
