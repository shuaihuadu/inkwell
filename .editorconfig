# EditorConfig: https://editorconfig.org
root = true

# 所有文件的默认设置
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# C# 文件
[*.cs]
indent_size = 4

# csproj / props / targets / slnx (XML)
[*.{csproj,props,targets,slnx}]
indent_size = 2

# sln 文件（Visual Studio 要求 CRLF）
[*.sln]
end_of_line = crlf

# PowerShell 脚本（Windows 惯例 CRLF）
[*.ps1]
end_of_line = crlf

# TypeScript / JavaScript / React
[*.{ts,tsx,js,jsx}]
indent_size = 2

# JSON
[*.json]
indent_size = 2

# CSS / HTML
[*.{css,html}]
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false

# Makefile（必须用 Tab）
[Makefile]
indent_style = tab
