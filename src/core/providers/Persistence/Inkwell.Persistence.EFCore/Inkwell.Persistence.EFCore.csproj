<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <RootNamespace>Inkwell.Persistence.EFCore</RootNamespace>
        <AssemblyName>Inkwell.Persistence.EFCore</AssemblyName>
        <!--
      ADR-021 EFCore family shared base：仅依赖 Inkwell.Abstractions + Microsoft.EntityFrameworkCore。
      final adapter（SqlServer / Postgres）可引用本 csproj；本 csproj 不引用 Inkwell.Core。
    -->
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\..\Inkwell.Abstractions\Inkwell.Abstractions.csproj" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.EntityFrameworkCore" />
        <PackageReference Include="Microsoft.EntityFrameworkCore.Relational" />
    </ItemGroup>

    <!-- final adapter（SqlServer / Postgres）借此访问本 csproj 的 internal 类型（AddEfCorePersistenceBase() / MigrationRunner / EfCorePersistenceProvider 等）。 -->
    <ItemGroup>
        <InternalsVisibleTo Include="Inkwell.Persistence.EFCore.SqlServer" />
        <InternalsVisibleTo Include="Inkwell.Persistence.EFCore.Postgres" />
        <!-- Inkwell.WebApi / Inkwell.Worker 是 DI 装配根，启动期需直接调用 internal MigrationRunner.SeedAsync()（ADR-019）。 -->
        <InternalsVisibleTo Include="Inkwell.WebApi" />
        <InternalsVisibleTo Include="Inkwell.Worker" />
        <!-- Inkwell.Migrator 是一次性 Migration + Seed 入口，需直接调用 internal MigrationRunner（ADR-024）。 -->
        <InternalsVisibleTo Include="Inkwell.Migrator" />
        <!-- RISK-002/011/012 验证地：跨 Provider 契约测试包需直接访问 InkwellDbContext 做 spike 验证。 -->
        <InternalsVisibleTo Include="Inkwell.Providers.Contract" />
    </ItemGroup>

</Project>
