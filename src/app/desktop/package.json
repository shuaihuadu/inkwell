{
  "name": "inkwell-desktop",
  "private": true,
  "version": "0.0.1-alpha",
  "description": "Inkwell desktop application",
  "author": "ShuaiHua Du",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "node scripts/run-electron-vite.mjs dev",
    "build": "tsc -b && electron-vite build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis msi --x64",
    "dist:mac": "npm run build && electron-builder --mac dmg zip --universal",
    "dist:linux": "npm run build && electron-builder --linux AppImage deb --x64",
    "lint": "eslint .",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test tests/login.spec.ts"
  },
  "dependencies": {
    "@ant-design/icons": "6.3.2",
    "@ant-design/x": "2.8.0",
    "@ant-design/x-markdown": "2.8.0",
    "@tanstack/react-query": "5.101.2",
    "antd": "6.5.1",
    "jszip": "3.10.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@playwright/test": "1.61.1",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "electron-vite": "3.1.0",
    "eslint": "9.39.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vite": "6.4.3",
    "vitest": "3.2.7"
  },
  "build": {
    "appId": "com.shuaihuadu.inkwell",
    "productName": "Inkwell",
    "buildVersion": "0.0.1.0",
    "asar": true,
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/logo.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "win": {
      "icon": "public/logo.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "category": "Utility",
      "icon": "public/logo.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
