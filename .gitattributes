# Auto detect text files and ensure LF line endings in the repo
* text=auto eol=lf

# C# source files
*.cs text eol=lf diff=csharp
*.csx text eol=lf diff=csharp
*.sln text eol=crlf
*.slnx text eol=lf
*.csproj text eol=lf
*.slnf text eol=lf
*.props text eol=lf
*.targets text eol=lf

# Frontend
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.vue text eol=lf

# Config / CI
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.config text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.ps1 text eol=crlf

# Docker
Dockerfile text eol=lf
*.dockerignore text eol=lf

# Git
.gitattributes text eol=lf
.gitignore text eol=lf
.editorconfig text eol=lf

# Binary files (no conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary
*.dll binary
*.exe binary
