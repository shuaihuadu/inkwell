# Auto detect text files and perform LF normalization
# 跨平台开发时，Git 会自动处理行尾符

# 默认行为：自动检测文本文件并规范化行尾符
* text=auto

# 源代码文件 - 强制使用 LF（推荐跨平台方案）
*.cs text eol=lf
*.csx text eol=lf
*.vb text eol=lf
*.vbx text eol=lf
*.resx text eol=lf
*.Designer.cs text eol=lf

# 项目文件
*.csproj text eol=lf
*.vbproj text eol=lf
*.fsproj text eol=lf
*.sln text eol=lf
*.slnx text eol=lf
*.slnf text eol=lf
*.props text eol=lf
*.targets text eol=lf

# 配置文件
*.json text eol=lf
*.xml text eol=lf
*.config text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
.editorconfig text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf

# Web 文件
*.html text eol=lf
*.htm text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.sass text eol=lf
*.less text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf

# Terraform / HCL 文件
*.tf text eol=lf
*.tfvars text eol=lf
*.hcl text eol=lf

# Helm 模板文件
*.tpl text eol=lf

# 脚本文件
*.sh text eol=lf
*.ps1 text eol=lf
*.psm1 text eol=lf
*.psd1 text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf

# 文档文件
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# SQL 文件
*.sql text eol=lf

# Docker 文件
Dockerfile text eol=lf
*.dockerfile text eol=lf
docker-compose*.yml text eol=lf

# 二进制文件 - 不做任何处理
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.dll binary
*.exe binary
*.pdb binary
*.nupkg binary
*.snupkg binary
*.zip binary
*.7z binary
*.gz binary
*.tar binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
